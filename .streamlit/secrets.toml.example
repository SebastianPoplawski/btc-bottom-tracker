# ============================================================================
#  SZABLON SEKRETOW  ->  skopiuj do  .streamlit/secrets.toml  i uzupelnij.
#  Prawdziwy plik secrets.toml jest w .gitignore i NIGDY nie trafia do repo.
#  Na Streamlit Community Cloud: wklej cala TRESC ponizej w panelu
#  "App settings -> Secrets" (ten sam format TOML).
# ============================================================================

# --- Tryb dzialania aplikacji ---
# "demo" = mock + seed (dziala bez chmury), "live" = realny BigQuery + Sheets
APP_MODE = "live"

# --- Identyfikatory (technicznie nie-tajne, ale wygodnie trzymac tutaj) ---
GCP_PROJECT_ID  = "twoj-projekt-gcp-id"
BQ_DATASET      = "btc_tracker"
BQ_LOCATION     = "EU"
GOOGLE_SHEET_ID = "id-arkusza-z-paska-adresu"   # https://docs.google.com/spreadsheets/d/<TO_ID>/edit

# --- Konto serwisowe Google (TO JEST TAJNE) ---
# Ten sam service account obsluguje BigQuery i Google Sheets.
# Wklej zawartosc pobranego pliku JSON, pole po polu:
[gcp_service_account]
type                        = "service_account"
project_id                  = "twoj-projekt-gcp-id"
private_key_id              = "..."
private_key                 = "-----BEGIN PRIVATE KEY-----\nWKLEJ_Z_ZACHOWANIEM_\\n\n-----END PRIVATE KEY-----\n"
client_email                = "btc-tracker-sa@twoj-projekt-gcp-id.iam.gserviceaccount.com"
client_id                   = "..."
auth_uri                    = "https://accounts.google.com/o/oauth2/auth"
token_uri                   = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url        = "..."
universe_domain             = "googleapis.com"
