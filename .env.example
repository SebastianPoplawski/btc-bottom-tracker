# ============================================================================
#  Alternatywa dla lokalnego uruchamiania: skopiuj do  .env  i uzupelnij.
#  .env jest w .gitignore. Uzywane gdy wolisz trzymac klucz jako PLIK
#  zamiast wklejac go do secrets.toml. Aplikacja czyta .streamlit/secrets.toml
#  jako pierwszy wybor; .env to wariant dla deweloperow.
# ============================================================================

APP_MODE=demo

GCP_PROJECT_ID=twoj-projekt-gcp-id
BQ_DATASET=btc_tracker
BQ_LOCATION=EU
GOOGLE_SHEET_ID=id-arkusza-z-paska-adresu

# Sciezka do pliku klucza service accounta (trzymaj go w folderze ./secrets/,
# ktory jest gitignored):
GOOGLE_APPLICATION_CREDENTIALS=./secrets/service_account.json
